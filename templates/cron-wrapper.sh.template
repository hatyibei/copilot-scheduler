#!/bin/bash
# copilot-scheduler: {{NAME}}
# Schedule: {{CRON}}
# Created: {{CREATED_AT}}
#
# This file was auto-generated by copilot-scheduler.
# Do not edit directly — use 'scripts/register-local.sh' to regenerate.

set -euo pipefail

# --- Environment Setup (cron runs with minimal env) ---
export HOME="{{HOME}}"
export PATH="{{NODE_BIN_DIR}}:/usr/local/bin:/usr/bin:/bin"
export NVM_DIR="{{HOME}}/.nvm"

# --- Proxy Settings (inherit from user env at registration time) ---
{{PROXY_EXPORTS}}

# --- GitHub Auth (required for copilot CLI in cron) ---
if [ -z "${GH_TOKEN:-}" ]; then
  GH_TOKEN="$(gh auth token 2>/dev/null || true)"
  if [ -n "$GH_TOKEN" ]; then
    export GH_TOKEN
  fi
fi

NAME="{{NAME}}"
PROMPT="{{PROMPT}}"
WORKING_DIR="{{WORKING_DIR}}"
LOG_DIR="{{LOG_DIR}}"
NOTIFY="{{NOTIFY}}"
COPILOT="{{COPILOT_PATH}}"
SCRIPT_DIR="{{SCRIPT_DIR}}"
LOCK_FILE="{{LOCK_DIR}}/${NAME}.lock"

mkdir -p "$LOG_DIR"

# --- Double-run prevention via flock ---
exec 200>"$LOCK_FILE"
if ! flock -n 200; then
  echo "[copilot-scheduler] ${NAME}: Already running. Skipping." >&2
  exit 0
fi

# --- Logging ---
LOGFILE="${LOG_DIR}/${NAME}_$(date +%Y%m%d_%H%M%S).log"

{
  echo "=== copilot-scheduler: ${NAME} ==="
  echo "Start: $(date --iso-8601=seconds)"
  echo "Prompt: ${PROMPT}"
  echo "Working Dir: ${WORKING_DIR}"
  echo "---"

  cd "$WORKING_DIR"

  # --- Execute Copilot ---
  "$COPILOT" -p "$PROMPT" --allow-all-tools --no-ask-user 2>&1
  EXIT_CODE=$?

  echo "---"
  echo "Exit Code: ${EXIT_CODE}"
  echo "End: $(date --iso-8601=seconds)"
} | tee "$LOGFILE"

EXIT_CODE=${PIPESTATUS[0]}

# --- Notification ---
if [ "$NOTIFY" = "issue" ] && [ -f "${SCRIPT_DIR}/notify.sh" ]; then
  bash "${SCRIPT_DIR}/notify.sh" --name "$NAME" --log-file "$LOGFILE" --method issue
fi

# --- Log rotation (delete logs older than 30 days) ---
find "$LOG_DIR" -name "${NAME}_*.log" -mtime +30 -delete 2>/dev/null || true

exit "${EXIT_CODE}"
